{
  "name": "pylon",
  "version": "0.2.4",
  "description": "Pylon desktop app",
  "main": "./out/main/index.js",
  "author": "iceinvein",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "lint": "tailwind-suggest-canonical-classes \"src/**/*.{tsx,jsx,ts,html}\" --css src/renderer/src/styles/globals.css --check && biome check src/",
    "lint:fix": "tailwind-suggest-canonical-classes \"src/**/*.{tsx,jsx,ts,html}\" --css src/renderer/src/styles/globals.css && biome check --write src/",
    "format": "biome format --write src/",
    "build:dmg": "bun scripts/build-dmg.ts --mac dmg --universal",
    "release": "bun scripts/release.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.101",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/instrument-serif": "^5.2.8",
    "@openai/codex-sdk": "^0.116.0",
    "@tailwindcss/vite": "^4.2.2",
    "ansi-to-html": "^0.7.2",
    "better-sqlite3": "^12.8.0",
    "d3-force": "^3.0.0",
    "diff": "^8.0.4",
    "lucide-react": "^0.575.0",
    "motion": "^12.38.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.0.2",
    "tailwindcss": "^4.2.2",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "0.24.7",
    "wouter": "^3.9.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@laststance/tailwind-suggest-canonical-classes": "^0.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3-force": "^3.0.10",
    "@types/diff": "^8.0.0",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^39.8.7",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2"
  }
}
